# URL of the FastAPI engine (Render in prod, localhost in dev).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — copy from Project Settings → API in the Supabase dashboard.
# The publishable/anon key is safe to expose to the browser (RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
